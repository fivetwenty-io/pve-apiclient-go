# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.out
coverage.html

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work
go.work.sum

# IDE specific files
.idea/
*.swp
*.swo
*~
.vscode/
*.code-workspace

# OS specific files
.DS_Store
Thumbs.db

# Project specific
/bin/
/dist/

# Example binaries (compiled from examples/*/main.go)
examples/*/advanced
examples/*/auth
examples/*/basic
examples/*/auto-login
examples/*/caching
examples/*/context-detection
examples/*/logging-slog
examples/*/logging-zap
examples/*/lxc-management
examples/*/metrics-prom
examples/*/vm-clone-start-cloudinit
examples/*/vm-cloudinit-start
